# Copy to deployment/oracle/.env on the Oracle VM. Never commit the real .env file.

# Public DNS name pointed at the VM. Caddy obtains and renews TLS automatically.
PUBLIC_HOSTNAME=api.example.com
CADDY_EMAIL=admin@example.com

# Public IPv4 address or DNS name used by clients for UDP game traffic.
PUBLIC_GAME_HOST=203.0.113.10

# Generate both with: openssl rand -hex 32
RIVET_ADMIN_TOKEN=replace_with_64_hex_characters
ALLOCATOR_SHARED_TOKEN=replace_with_different_64_hex_characters

# Supabase staging project. SUPABASE_SECRET_KEY must be a backend-only secret key.
SUPABASE_URL=https://mlwsxeqorlfgmxqxnfoo.supabase.co
SUPABASE_SECRET_KEY=replace_with_supabase_backend_secret

GODOT_VERSION=4.6.3
SUPPORTED_BUILD_ID=PHASE-05.3-ONLINE-PRODUCTION-COMPLETION
PROTOCOL_VERSION=3
MIN_PLAYERS=2
MAX_PLAYERS=6
QUEUE_TTL_SECONDS=120

# Local image names. The deployment script builds these from the validated source bundle.
CONTROL_PLANE_IMAGE=colony-rivet-control:staging
ALLOCATOR_IMAGE=colony-external-allocator:staging
GAME_SERVER_IMAGE=colony-dominion-server:staging

# Keep the UDP range aligned with Oracle Security List/NSG and the host firewall.
GAME_PORT_MIN=20000
GAME_PORT_MAX=20015
CONTROL_PORT_MIN=21000
CONTROL_PORT_MAX=21015
MAX_CONCURRENT_SERVERS=4
GAME_SERVER_CPU_MILLICORES=500
GAME_SERVER_MEMORY_MB=512
ASSIGNMENT_TTL_SECONDS=120
SERVER_MAX_LIFETIME_SECONDS=14400
SERVER_READY_TIMEOUT_SECONDS=45

# One enabled region for the first staging deployment.
REGIONS_JSON=[{"id":"eu","displayName":"Avrupa","shortName":"EU","probeUrl":"","enabled":true,"providerRegion":"oracle-primary"}]
