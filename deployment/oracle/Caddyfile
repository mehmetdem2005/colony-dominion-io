{
  email {$CADDY_EMAIL}
  servers {
    timeouts {
      read_body 30s
      read_header 10s
      write 1h
      idle 1h
    }
  }
}

{$PUBLIC_HOSTNAME} {
  encode zstd gzip

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "no-referrer"
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
    -Server
  }

  request_body {
    max_size 1MB
  }

  reverse_proxy control-plane:3000 {
    transport http {
      dial_timeout 10s
      response_header_timeout 1h
      read_timeout 1h
      write_timeout 1h
      keepalive 2m
    }
  }

  log {
    output stdout
    format json
  }
}
