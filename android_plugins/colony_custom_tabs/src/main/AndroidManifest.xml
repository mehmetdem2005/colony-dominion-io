<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application>
        <!-- Registers the plugin with Godot's v2 Android plugin runtime so the
             ColonyCustomTabs singleton actually loads. Without this meta-data the
             plugin AAR ships but is never instantiated, and sign-in falls back to
             OS.shell_open (the external browser). -->
        <meta-data
            android:name="org.godotengine.plugin.v2.ColonyCustomTabs"
            android:value="io.colonydominion.customtabs.ColonyCustomTabs" />
    </application>
</manifest>
